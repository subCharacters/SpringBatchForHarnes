#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/log.sh"

HOOK="GIT:pre-commit"

# =====================
# 머지 커밋 스킵
# =====================
if [ -f ".git/MERGE_HEAD" ]; then
  echo_log "$HOOK" "⏭️  머지 커밋 감지 — 훅 스킵"
  exit 0
fi

# =====================
# 브랜치 직접 커밋 차단
# =====================
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

echo_log "$HOOK" "🔍 브랜치 체크 중... ($BRANCH)"
if [ "$BRANCH" = "master" ] || [ "$BRANCH" = "main" ]; then
  log_fail "$HOOK" "$BRANCH 브랜치 직접 커밋 시도 차단"
  log_error "$HOOK" "$BRANCH 브랜치 직접 커밋 차단" "브랜치: $BRANCH"
  echo_log "$HOOK" "❌ $BRANCH 브랜치에서 직접 커밋 금지! worktree를 먼저 생성하세요."
  echo_log "$HOOK" "👉 git worktree add .worktrees/<작업명> -b <브랜치명>"
  exit 1
fi
echo_log "$HOOK" "✅ 브랜치 체크 통과! ($BRANCH)"

# =====================
# 코드 품질 검사
# =====================
bash "$SCRIPT_DIR/commit-verify.sh"
exit $?
