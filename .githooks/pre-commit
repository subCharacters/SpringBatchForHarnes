#!/bin/bash

# 머지 커밋은 패스
if [ -f ".git/MERGE_HEAD" ]; then
  exit 0
fi

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$BRANCH" = "master" ] || [ "$BRANCH" = "main" ]; then
  echo "❌ $BRANCH 브랜치에서 직접 커밋 금지! worktree를 먼저 생성하세요."
  echo "👉 git worktree add .worktrees/<작업명> -b <브랜치명>"
  exit 1
fi

# 1. 컴파일 체크 (가장 빠름)
echo "🔍 컴파일 체크 중..."
./gradlew compileJava compileTestJava
if [ $? -ne 0 ]; then
  echo "❌ 컴파일 실패! 코드를 확인하세요." >&2
  exit 1
fi
echo "✅ 컴파일 통과!"

# 2. 빌드 체크 (테스트 제외)
echo "🔍 빌드 체크 중..."
./gradlew build -x test
if [ $? -ne 0 ]; then
  echo "❌ 빌드 실패! 코드를 확인하세요." >&2
  exit 1
fi
echo "✅ 빌드 통과!"

# 3. 테스트 및 커버리지 체크 (가장 느림, 마지막)
echo "🔍 테스트 및 커버리지 체크 중..."
./gradlew test jacocoTestReport jacocoTestCoverageVerification
if [ $? -ne 0 ]; then
  echo "❌ 커버리지 80% 미달! 테스트를 보완하고 다시 커밋해주세요." >&2
  exit 1
fi
echo "✅ 커버리지 체크 통과!"
exit 0
